# Firebase Admin SDK
FIREBASE_PROJECT_ID=seu-projeto-firebase
FIREBASE_CLIENT_EMAIL=seu-email@projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nsua-chave-privada\n-----END PRIVATE KEY-----\n"

# Server
PORT=3001
NODE_ENV=development

# Redis (para Bull Queue - Render fornece gratuitamente)
REDIS_URL=redis://localhost:6379

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Upload-Post (agendamento externo)
UPLOAD_POST_API_KEY=sua-chave-upload-post
# Fuso horário (IANA) usado ao agendar posts no Upload-Post
UPLOAD_POST_TIMEZONE=America/Sao_Paulo

# ElevenLabs TTS para narração dos Reels
ELEVENLABS_API_KEY=sua-chave-elevenlabs
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
